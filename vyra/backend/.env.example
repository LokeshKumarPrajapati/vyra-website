# ──────────────────────────────────────────────────────────────────────────────
# Vyra Environment Configuration
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────────────────────

# ── Spotify ──────────────────────────────────────────────────────────────────
# Get your Client ID from: https://developer.spotify.com/dashboard → Your App → Settings
# Only the Client ID is needed (PKCE flow — no secret required).
SPOTIFY_CLIENT_ID=68302b4c935244aebba226f19efc6b6b

# Redirect URI (must match what you set in your Spotify App dashboard)
# Default: http://localhost:8000/spotify/callback
SPOTIFY_REDIRECT_URI=http://localhost:8000/spotify/callback

# ── Google Gemini ─────────────────────────────────────────────────────────────
# GEMINI_API_KEY=your_gemini_api_key_here
